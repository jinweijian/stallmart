{
  "name": "stallmart-mini-program",
  "version": "1.0.0",
  "description": "StallMart WeChat Mini Program - Taro + Vue3",
  "private": true,
  "scripts": {
    "dev:weapp": "taro build --type weapp --watch",
    "build:weapp": "taro build --type weapp",
    "postbuild:weapp": "node scripts/sync-weapp-static.mjs",
    "dev:h5": "taro build --type h5 --watch",
    "build:h5": "taro build --type h5",
    "lint": "eslint src --ext .vue,.js,.jsx,.ts,.tsx",
    "lint:fix": "eslint src --ext .vue,.js,.jsx,.ts,.tsx --fix",
    "format": "prettier --write \"src/**/*.{vue,js,jsx,ts,tsx,json,css,scss}\"",
    "test:weapp-assets": "node scripts/verify-weapp-assets-and-styles.mjs",
    "test:taro-versions": "node scripts/verify-taro-versions.mjs"
  },
  "dependencies": {
    "@tarojs/api": "4.2.0",
    "@tarojs/components": "4.2.0",
    "@tarojs/plugin-framework-react": "4.2.0",
    "@tarojs/plugin-framework-vue3": "4.2.0",
    "@tarojs/plugin-platform-weapp": "4.2.0",
    "@tarojs/runtime": "4.2.0",
    "@tarojs/taro": "4.2.0",
    "@vicons/ionicons5": "^0.12.0",
    "pinia": "^2.1.7",
    "vue": "^3.4.21"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@babel/preset-env": "^7.29.2",
    "@babel/preset-typescript": "^7.28.5",
    "@tarojs/cli": "4.2.0",
    "@tarojs/plugin-platform-h5": "4.2.0",
    "@tarojs/webpack5-runner": "4.2.0",
    "@types/node": "^20.11.0",
    "@types/wechat-miniprogram": "^3.0.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@vue/compiler-sfc": "^3.4.21",
    "autoprefixer": "^10.4.18",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.3",
    "eslint-plugin-vue": "^9.22.0",
    "postcss": "^8.4.35",
    "prettier": "^3.2.5",
    "style-loader": "^3.3.4",
    "tailwindcss": "^3.4.1",
    "ts-loader": "^9.5.1",
    "typescript": "^5.3.3",
    "vue-loader": "^17.4.2",
    "webpack": "^5.90.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
