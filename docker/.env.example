# ================================================
# StallMart 本地开发环境配置
# ================================================
# 注意：禁止将任何服务暴露到公网！
# 本地开发环境，仅限 localhost 访问
# ================================================

# Java 后端
SPRING_PROFILES_ACTIVE=dev
SERVER_PORT=8080

# MySQL
MYSQL_VERSION=9.0
MYSQL_ROOT_PASSWORD=stallmart_dev_root
MYSQL_DATABASE=stallmart
MYSQL_USER=stallmart
MYSQL_PASSWORD=stallmart_dev_pass
# 仅监听本地端口，不暴露到外网
MYSQL_PORT=3306

# Redis
REDIS_VERSION=7.2-alpine
REDIS_PASSWORD=stallmart_dev_redis
# 仅监听本地端口，不暴露到外网
REDIS_PORT=6379

# JWT 密钥（生产环境必须修改！）
JWT_SECRET=your-256-bit-secret-key-here-change-in-production-min-32-chars

# 阿里云 OSS（可选，本地开发可注释）
# OSS_ACCESS_KEY_ID=your_access_key
# OSS_ACCESS_KEY_SECRET=your_secret_key
# OSS_BUCKET=stallmart
# OSS_ENDPOINT=oss-cn-hangzhou.aliyuncs.com

# 微信小程序（开发环境使用测试号或本地配置）
WECHAT_APP_ID=your_wechat_app_id
WECHAT_APP_SECRET=your_wechat_app_secret
